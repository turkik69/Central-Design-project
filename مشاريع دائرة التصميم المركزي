/* ════════════ العرض ════════════ */
function render(){
  root.innerHTML='';
  if(!state.appUser){root.appendChild(renderAuth());return;}
  root.appendChild(renderApp());
}

function renderAuth(){
  const isNew=state.isNewUser;
  const wrap=$(`<div class="auth-wrap"><div class="auth-pattern"></div></div>`);
  const card=$(`<div class="auth-card">
    <div class="auth-logo">
      <div class="auth-crest">بم</div>
      <h1>مشاريع التصميم المركزي</h1>
      <div class="sub">المديرية العامة للشؤون الفنية — بلدية مسقط</div>
    </div>
  </div>`);
  if(state.authError) card.appendChild($(`<div class="err">${state.authError}</div>`));

  const form=document.createElement('form');
  form.innerHTML = (isNew?`
    <div class="field"><label>الاسم الكامل</label><input type="text" name="name" required></div>
    <div class="field"><label>المسمى الوظيفي</label>
      <select name="jobTitle">
        <option>مهندس معماري</option><option>مهندس إنشائي</option><option>مهندس تصميم خدمات</option>
        <option>رئيس القسم المعماري</option><option>رئيس القسم الإنشائي</option><option>رئيس قسم تصميم الخدمات</option>
        <option>مدير الدائرة</option><option>تنسيق ومتابعة</option>
      </select></div>
    <div class="field"><label>القسم الفني المختص</label>
      <select name="dept"><option value="architectural">القسم المعماري</option>
        <option value="structural">القسم الإنشائي</option><option value="services">قسم تصميم الخدمات</option></select></div>
  `:``)+`
    <div class="field"><label>اسم المستخدم</label><input class="ltr" type="text" name="username" required placeholder="username"></div>
    <div class="field"><label>الرقم السري</label><input class="ltr" type="password" name="password" required></div>
    <button class="btn-primary" type="submit" ${state.loading?'disabled':''}>
      ${state.loading?'<div class="spinner"></div>':(isNew?'إنشاء الحساب':'تسجيل الدخول')}
    </button>`;
  form.onsubmit=(e)=>{e.preventDefault();handleAuth(form);};
  card.appendChild(form);

  const sw=$(`<button class="switch-link">${isNew?'لديكِ حساب؟ تسجيل الدخول':'مستخدمة جديدة؟ إنشاء حساب'}</button>`);
  sw.onclick=()=>{state.isNewUser=!state.isNewUser;state.authError='';render();};
  card.appendChild(sw);

  wrap.appendChild(card);
  return wrap;
}

function renderApp(){
  const u=state.appUser; const frag=document.createDocumentFragment();

  /* الشريط العلوي */
  const header=$(`<header class="topbar"><div class="topbar-inner">
    <div class="brand"><div class="brand-crest">بم</div>
      <div><h1>التصميم المركزي</h1><div class="crumb">بلدية مسقط · الشؤون الفنية</div></div></div>
    <div class="search">${I.search}<input type="text" placeholder="ابحثي عن مشروع أو جهة طالبة…" value="${state.search}"></div>
    <div class="user-box">
      <div class="user-meta"><div class="nm">${u.name}</div><div class="rl">${u.role==='admin'?'مشرف عام':(u.jobTitle||'مهندس مصمم')}</div></div>
      <div class="avatar">${u.profilePic?`<img src="${u.profilePic}">`:I.user}</div>
      <button class="icon-btn" id="btnProfile" title="إعدادات الحساب">${I.settings}</button>
      <button class="icon-btn" id="btnLogout" title="تسجيل الخروج">${I.logout}</button>
    </div></div></header>`);
  const searchInp=header.querySelector('.search input');
  searchInp.oninput=(e)=>{state.search=e.target.value;applyFilter();updateGrid();};
  header.querySelector('#btnLogout').onclick=logout;
  header.querySelector('#btnProfile').onclick=openProfile;
  frag.appendChild(header);

  /* المحتوى */
  const main=document.createElement('main');

  if(!CONFIGURED){
    main.appendChild($(`<div class="setup-banner">
      <b>⚙ التطبيق يعمل في وضع المعاينة.</b> الدخول كمشرف متاح، لكن حفظ المشاريع وحسابات المهندسين معطّلة
      حتى تُضاف مفاتيح <code>firebaseConfig</code> في أعلى ملف <code>index.html</code>. الدليل في رسالة كلود.
    </div>`));
  }

  const toolbar=$(`<div class="toolbar">
    <h2>قائمة المشاريع <span>(${state.filtered.length})</span></h2>
    <div class="tb-actions">
      ${u.role==='admin'?`
        <button class="btn btn-del" id="btnClear">${I.trash}<span class="lbl">مسح الكل</span></button>
        <button class="btn btn-xl" id="btnXl">${I.upload}<span class="lbl">استيراد Excel</span></button>
        <input type="file" id="xlFile" accept=".xlsx,.xls" class="hidden">`:''}
      <button class="btn btn-add" id="btnAdd">${I.plus}<span class="lbl">إضافة مشروع</span></button>
    </div></div>`);
  if(u.role==='admin'){
    const xl=toolbar.querySelector('#xlFile');
    toolbar.querySelector('#btnXl').onclick=()=>xl.click();
    xl.onchange=(e)=>{handleExcelImport(e.target.files[0]); e.target.value='';};
    toolbar.querySelector('#btnClear').onclick=clearAll;
  }
  toolbar.querySelector('#btnAdd').onclick=()=>openProjectModal(null);
  main.appendChild(toolbar);

  const gridHost=document.createElement('div');
  gridHost.id='gridHost';
  main.appendChild(gridHost);
  frag.appendChild(main);

  setTimeout(updateGrid,0);
  return frag;
}

function updateGrid(){
  const host=document.getElementById('gridHost');
  if(!host) return;
  host.innerHTML='';
  if(state.loading){host.appendChild($(`<div class="loading"><div class="spinner"></div></div>`));return;}
  if(!state.filtered.length){
    host.appendChild($(`<div class="empty">${I.build}<h3 style="margin-top:12px;font-size:18px;color:#5e574a">لا توجد مشاريع لعرضها</h3>
      <p style="margin-top:5px">أضيفي أول مشروع بالضغط على «إضافة مشروع».</p></div>`));
    return;
  }
  const grid=document.createElement('div');grid.className='grid';
  state.filtered.forEach(p=>grid.appendChild(renderCard(p)));
  host.appendChild(grid);
}

function secRow(title,data){
  const st=data?.status||'قيد الانتظار';
  const [c,bg]=SEC_STYLE[st]||SEC_STYLE['قيد الانتظار'];
  return `<div class="sec"><div class="sec-l">
      <span class="dot" style="background:${c}"></span>
      <div><div class="ttl">${title}</div><div class="eng">${data?.engineer||'لم يُسنَد'}</div></div>
    </div><span class="sec-badge" style="color:${c};background:${bg}">${st}</span></div>`;
}

function renderCard(p){
  const [sc,sbg]=STATUS_STYLE[p.overallStatus]||STATUS_STYLE['قيد التصميم'];
  const isAdmin=state.appUser.role==='admin';
  const card=$(`<div class="card">
    <div class="card-head">
      <div class="row1">
        <span class="tag">${p.customType||p.type||'مشروع'}</span>
        <span class="pill" style="color:${sc};background:${sbg};border-color:${sc}33">${p.overallStatus||'قيد التصميم'}</span>
      </div>
      <h3>${p.name||''}</h3>
      <div class="entity">${I.pin} ${p.requestingEntity||'—'}</div>
    </div>
    <div class="card-body">
      <div class="meta-grid">
        <div><span class="k">المساحة:</span> <span class="v">${p.area||'—'}</span></div>
        <div><span class="k">التكلفة:</span> <span class="v">${p.cost||'—'}</span></div>
        <div><span class="k">${I.cal} الاستلام:</span> <span class="v">${p.startDate||'—'}</span></div>
        <div><span class="k">${I.cal} التسليم:</span> <span class="v">${p.endDate||'—'}</span></div>
      </div>
      ${secRow('المعماري',p.architectural)}
      ${secRow('الإنشائي',p.structural)}
      ${secRow('الخدمات',p.services)}
    </div>
    <div class="card-foot">
      <div class="upd">حدّثه: ${p.lastUpdatedBy||'النظام'}<br>${p.lastUpdatedAt||''}</div>
      <div class="acts">
        <button class="act act-edit" title="تحديث">${I.edit}</button>
        ${isAdmin?`<button class="act act-del" title="حذف">${I.trash}</button>`:''}
      </div>
    </div></div>`);
  card.querySelector('.act-edit').onclick=()=>openProjectModal(p);
  if(isAdmin){
    const delBtn=card.querySelector('.act-del');
    delBtn.style.position='relative';
    delBtn.onclick=(e)=>{
      e.stopPropagation();
      if(card.querySelector('.confirm-pop')) return;
      const pop=$(`<div class="confirm-pop"><p>تأكيد الحذف؟</p>
        <div class="cp-btns"><button class="yes" style="background:var(--danger);color:#fff">نعم</button>
        <button class="no" style="background:var(--sand-200);color:#4a443a">لا</button></div></div>`);
      pop.querySelector('.yes').onclick=()=>deleteProject(p.id);
      pop.querySelector('.no').onclick=()=>pop.remove();
      delBtn.appendChild(pop);
    };
  }
  return card;
}

/* ════════════ نافذة المشروع ════════════ */
function openProjectModal(project){
  const data = project ? JSON.parse(JSON.stringify(project)) : {
    name:'',type:'حديقة',customType:'',requestingEntity:'مسقط',area:'',cost:'',
    overallStatus:'قيد التصميم',startDate:'',endDate:'',
    architectural:{engineer:'',status:'قيد الانتظار',notes:''},
    structural:{engineer:'',status:'قيد الانتظار',notes:''},
    services:{engineer:'',status:'قيد الانتظار',notes:''}
  };
  const entities=['مسقط','مطرح','بوشر','السيب','العامرات','قريات',
    'المديرية العامة للشؤون الصحية','المديرية العامة للتخطيط والاستثمار',
    'المديرية العامة للمشاريع والتشجير','جهة أخرى…'];
  const opt=(arr,sel)=>arr.map(o=>`<option ${o===sel?'selected':''}>${o}</option>`).join('');

  const overlay=$(`<div class="overlay"></div>`);
  const modal=$(`<div class="modal"><div class="modal-head"><h2>${project?'تحديث المشروع':'إضافة مشروع جديد'}</h2>
    <button class="icon-btn" id="x">${I.close}</button></div></div>`);
  const form=document.createElement('form');form.className='modal-body';
  form.innerHTML=`
    <div class="form-grid">
      <div><label class="lbl-sm">اسم المشروع</label><input class="inp" name="name" required value="${data.name}"></div>
      <div><label class="lbl-sm">الجهة الطالبة</label><select class="inp" name="requestingEntity">${opt(entities,data.requestingEntity)}</select></div>
      <div><label class="lbl-sm">الوضع العام</label><select class="inp" name="overallStatus" style="font-weight:700">
        ${opt(['قيد التصميم','مكتمل','متوقف الى اشعار اخر','الغي المشروع'],data.overallStatus)}</select></div>
      <div><label class="lbl-sm">النوع</label><select class="inp" name="type">${opt(['حديقة','ممشى','مبنى','أخرى'],data.type)}</select>
        <input class="inp ${data.type==='أخرى'?'':'hidden'}" name="customType" id="ct" placeholder="اكتبي نوع المشروع…" value="${data.customType||''}" style="margin-top:8px"></div>
      <div><label class="lbl-sm">المساحة</label><input class="inp" name="area" value="${data.area||''}"></div>
      <div><label class="lbl-sm">التكلفة (ر.ع)</label><input class="inp" name="cost" value="${data.cost||''}"></div>
      <div><label class="lbl-sm">تاريخ الاستلام</label><input class="inp" type="date" name="startDate" value="${data.startDate||''}"></div>
      <div><label class="lbl-sm">تاريخ التسليم</label><input class="inp" type="date" name="endDate" value="${data.endDate||''}"></div>
    </div>
    <div class="divider"></div>
    <div class="dept-grid">
      ${deptCard('القسم المعماري','architectural',data.architectural)}
      ${deptCard('القسم الإنشائي','structural',data.structural)}
      ${deptCard('قسم الخدمات','services',data.services)}
    </div>
    <div class="modal-foot">
      <button type="button" class="btn btn-ghost" id="cancel">إلغاء</button>
      <button type="submit" class="btn btn-add">${I.save} حفظ التغييرات</button>
    </div>`;
  // إظهار حقل النوع المخصص
  form.querySelector('[name=type]').onchange=(e)=>{
    form.querySelector('#ct').classList.toggle('hidden',e.target.value!=='أخرى');
  };
  form.onsubmit=async(e)=>{
    e.preventDefault();
    const fd=new FormData(form);
    const get=(n)=>fd.get(n)||'';
    const payload={
      name:get('name'),type:get('type'),customType:get('customType'),
      requestingEntity:get('requestingEntity'),overallStatus:get('overallStatus'),
      area:get('area'),cost:get('cost'),startDate:get('startDate'),endDate:get('endDate'),
      architectural:{engineer:get('arch_engineer'),status:get('arch_status'),notes:get('arch_notes')},
      structural:{engineer:get('str_engineer'),status:get('str_status'),notes:get('str_notes')},
      services:{engineer:get('srv_engineer'),status:get('srv_status'),notes:get('srv_notes')}
    };
    if(!CONFIGURED){alert('قاعدة البيانات غير مُعدّة بعد — أضيفي مفاتيح Firebase أولاً لحفظ المشاريع.');return;}
    overlay.remove();
    await saveProject(payload, project?.id);
  };
  modal.querySelector('#x').onclick=()=>overlay.remove();
  form.querySelector('#cancel').onclick=()=>overlay.remove();
  modal.appendChild(form);
  overlay.appendChild(modal);
  overlay.onclick=(e)=>{if(e.target===overlay)overlay.remove();};
  root.appendChild(overlay);
}
function deptCard(title,prefixKey,d){
  const pf={architectural:'arch',structural:'str',services:'srv'}[prefixKey];
  const sOpt=['قيد الانتظار','قيد العمل','مكتمل'].map(o=>`<option ${o===(d.status||'قيد الانتظار')?'selected':''}>${o}</option>`).join('');
  return `<div class="dept"><h4>${title}</h4>
    <input class="inp" name="${pf}_engineer" placeholder="اسم المهندس" value="${d.engineer||''}">
    <select class="inp" name="${pf}_status">${sOpt}</select>
    <textarea class="inp" name="${pf}_notes" rows="2" placeholder="ملاحظات…" style="resize:none">${d.notes||''}</textarea>
  </div>`;
}

/* ════════════ نافذة الملف الشخصي ════════════ */
function openProfile(){
  const u=state.appUser;
  const overlay=$(`<div class="overlay"></div>`);
  const modal=$(`<div class="modal modal-sm"><div class="modal-head"><h2>إعدادات الحساب</h2>
    <button class="icon-btn" id="x">${I.close}</button></div></div>`);
  const form=document.createElement('form');form.className='modal-body';
  form.innerHTML=`
    <div style="display:flex;flex-direction:column;align-items:center;margin-bottom:18px">
      <div class="avatar" id="pv" style="width:90px;height:90px;border:2px solid var(--oasis);background:var(--sand-100)">
        ${u.profilePic?`<img src="${u.profilePic}">`:I.user}</div>
      <label style="cursor:pointer;color:var(--oasis-600);font-size:13px;font-weight:600;margin-top:10px;display:flex;align-items:center;gap:5px">
        ${I.img} تغيير الصورة <input type="file" accept="image/*" id="imgUp" class="hidden"></label>
    </div>
    <div class="field"><label class="lbl-sm">الرقم السري الجديد (اختياري)</label>
      <input class="inp ltr" type="password" name="newPassword" placeholder="للتغيير فقط"></div>
    <div class="modal-foot">
      <button type="button" class="btn btn-ghost" id="cancel">إلغاء</button>
      <button type="submit" class="btn btn-add">حفظ</button>
    </div>`;
  let newPic=null;
  form.querySelector('#imgUp').onchange=(e)=>{
    const f=e.target.files[0];if(!f)return;
    const r=new FileReader();r.onload=(ev)=>{newPic=ev.target.result;
      form.querySelector('#pv').innerHTML=`<img src="${newPic}">`;};
    r.readAsDataURL(f);
  };
  form.onsubmit=async(e)=>{
    e.preventDefault();
    const np=new FormData(form).get('newPassword');
    if(u.role==='admin'){ // المشرف ثابت محلياً
      if(newPic){state.appUser.profilePic=newPic;}
      overlay.remove();render();return;
    }
    if(CONFIGURED){
      try{
        const qs=await getDocs(query(usersRef(),where("username","==",u.username)));
        if(!qs.empty){
          const ref=doc(db,'artifacts',APP_ID,'public','data','users',qs.docs[0].id);
          const upd={}; if(np)upd.password=np; if(newPic)upd.profilePic=newPic;
          if(Object.keys(upd).length) await updateDoc(ref,upd);
          state.appUser={...state.appUser,...upd};
        }
      }catch(err){console.error(err);}
    }
    overlay.remove();render();
  };
  modal.querySelector('#x').onclick=()=>overlay.remove();
  form.querySelector('#cancel').onclick=()=>overlay.remove();
  modal.appendChild(form);overlay.appendChild(modal);
  overlay.onclick=(e)=>{if(e.target===overlay)overlay.remove();};
  root.appendChild(overlay);
}

/* ---- إقلاع ---- */
initFirebase();
render();
</script>

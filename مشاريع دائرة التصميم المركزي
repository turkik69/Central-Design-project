<body>
<div id="root"></div>

<!-- ============ Firebase + التطبيق ============ -->
<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
import { getAuth, signInAnonymously, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-auth.js";
import { getFirestore, collection, onSnapshot, addDoc, updateDoc, deleteDoc, doc, getDocs, query, where, writeBatch }
  from "https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js";

/* ════════════════════════════════════════════════════════════════
   ❶  ضعي مفاتيح مشروع Firebase الخاص بكِ هنا فقط
   احصلي عليها من: console.firebase.google.com ← إعدادات المشروع ← تطبيق ويب
   (الدليل خطوة بخطوة في رسالة كلود)
   ════════════════════════════════════════════════════════════════ */
const firebaseConfig = {
  apiKey: "ضعي_المفتاح_هنا",
  authDomain: "ضعي_القيمة_هنا.firebaseapp.com",
  projectId: "ضعي_معرف_المشروع_هنا",
  storageBucket: "ضعي_القيمة_هنا.appspot.com",
  messagingSenderId: "ضعي_القيمة_هنا",
  appId: "ضعي_القيمة_هنا"
};
const APP_ID = "muscat-design-app";
/* ════════════════════════════════════════════════════════════════ */

const CONFIGURED = !firebaseConfig.apiKey.startsWith("ضعي");
let db=null, auth=null;
if (CONFIGURED){
  const app = initializeApp(firebaseConfig);
  auth = getAuth(app);
  db = getFirestore(app);
}

const $ = (h)=>{const t=document.createElement('template');t.innerHTML=h.trim();return t.content.firstChild;};
const root = document.getElementById('root');

/* ---- الحالة ---- */
const state = {
  fbReady:false, appUser:null, projects:[], filtered:[],
  search:'', isNewUser:false, authError:'', loading:true
};
const ADMIN = { user:'turki69', pass:'abuyassmin69' };
const colRef = ()=> collection(db,'artifacts',APP_ID,'public','data','projects');
const usersRef = ()=> collection(db,'artifacts',APP_ID,'public','data','users');

const STATUS_STYLE = {
  'مكتمل':['var(--ok)','var(--ok-bg)'],
  'قيد التصميم':['var(--work)','var(--work-bg)'],
  'متوقف الى اشعار اخر':['var(--stop)','var(--stop-bg)'],
  'الغي المشروع':['var(--cancel)','var(--cancel-bg)']
};
const SEC_STYLE = {
  'مكتمل':['var(--ok)','var(--ok-bg)'],
  'قيد العمل':['var(--work)','var(--work-bg)'],
  'قيد الانتظار':['var(--wait)','var(--wait-bg)']
};

/* ---- المصادقة على Firebase (مجهول) ---- */
function initFirebase(){
  if(!CONFIGURED){state.fbReady=true;state.loading=false;render();return;}
  signInAnonymously(auth).catch(e=>console.error("مصادقة:",e));
  onAuthStateChanged(auth,(u)=>{
    if(u){state.fbReady=true; subscribeProjects();}
  });
}
function subscribeProjects(){
  onSnapshot(colRef(),(snap)=>{
    const data = snap.docs.map(d=>({id:d.id,...d.data()}));
    data.sort((a,b)=> new Date(b.createdAt) - new Date(a.createdAt));
    state.projects=data; applyFilter(); state.loading=false; render();
  },(e)=>{console.error("جلب المشاريع:",e);state.loading=false;render();});
}
function applyFilter(){
  const s=state.search.trim().toLowerCase();
  state.filtered = !s ? state.projects : state.projects.filter(p=>
    (p.name||'').toLowerCase().includes(s) ||
    (p.requestingEntity||'').toLowerCase().includes(s) ||
    (p.type||'').toLowerCase().includes(s));
}

/* ════════════ تسجيل الدخول ════════════ */
async function handleAuth(form){
  state.authError='';state.loading=true;render();
  const fd=new FormData(form);
  const username=(fd.get('username')||'').trim().toLowerCase();
  const password=(fd.get('password')||'').trim();

  if(username===ADMIN.user && password.toLowerCase()===ADMIN.pass){
    state.appUser={role:'admin',name:'تركي (المشرف العام)',username,profilePic:''};
    state.loading=false;render();return;
  }
  if(!CONFIGURED){
    state.authError='قاعدة البيانات غير مُعدّة بعد — لا يمكن تسجيل دخول المهندسين حتى تُضاف مفاتيح Firebase.';
    state.loading=false;render();return;
  }
  try{
    if(state.isNewUser){
      const name=(fd.get('name')||'').trim();
      const dept=fd.get('dept'); const jobTitle=fd.get('jobTitle');
      const dup=await getDocs(query(usersRef(),where("username","==",username)));
      if(!dup.empty){state.authError='اسم المستخدم محجوز مسبقاً، اختاري اسماً آخر.';state.loading=false;render();return;}
      const newUser={username,password,name,role:'engineer',dept,jobTitle,profilePic:''};
      await addDoc(usersRef(),newUser);
      state.appUser=newUser;
    }else{
      const qs=await getDocs(query(usersRef(),where("username","==",username),where("password","==",password)));
      if(qs.empty){state.authError='اسم المستخدم أو الرقم السري غير صحيح.';}
      else{state.appUser=qs.docs[0].data();}
    }
  }catch(e){console.error(e);state.authError='تعذّر الاتصال، حاولي مرة أخرى.';}
  state.loading=false;render();
}
function logout(){state.appUser=null;state.isNewUser=false;state.authError='';render();}

/* ════════════ استيراد Excel ════════════ */
function handleExcelImport(file){
  if(!file||!CONFIGURED) return;
  state.loading=true;render();
  const reader=new FileReader();
  reader.onload=async(evt)=>{
    try{
      const wb=window.XLSX.read(evt.target.result,{type:'binary'});
      const ws=wb.Sheets[wb.SheetNames[0]];
      const rows=window.XLSX.utils.sheet_to_json(ws,{header:1});
      let cur=null; const out=[]; const now=new Date().toLocaleString('ar-OM');
      for(const row of rows){
        if(!row||!row.length) continue;
        const c1=String(row[0]||'').trim(), c2=String(row[1]||'').trim(), c3=String(row[2]||'').trim();
        const t=c2||c1; if(!t) continue;
        if(t.includes('دائرة')||t.includes('تتبع المشاريع')||t.includes('اسم المشروع')||t.includes('تاريخ تحديث')) continue;
        if(t.includes('المعماري -')){ if(cur){cur.architectural.engineer=t.replace('المعماري -','').trim(); if(c3&&c3!=='-')cur.requestingEntity=c3;} }
        else if(t.includes('الانشائي -')){ if(cur)cur.structural.engineer=t.replace('الانشائي -','').trim(); }
        else if(t.includes('الخدمات -')){ if(cur)cur.services.engineer=t.replace('الخدمات -','').trim(); }
        else if(t.length>3 && !/^[0-9]+$/.test(t)){
          if(cur&&cur.name) out.push(cur);
          cur={name:t,type:'أخرى',customType:'استيراد من الإكسل',
            requestingEntity:(c3&&c3!=='-')?c3:'غير محدد',overallStatus:'قيد التصميم',
            area:'',cost:'',startDate:'',endDate:'',
            architectural:{engineer:'',status:'قيد الانتظار',notes:''},
            structural:{engineer:'',status:'قيد الانتظار',notes:''},
            services:{engineer:'',status:'قيد الانتظار',notes:''},
            lastUpdatedBy:state.appUser.name,lastUpdatedAt:now,createdAt:new Date().toISOString()};
        }
      }
      if(cur&&cur.name) out.push(cur);
      for(const p of out) await addDoc(colRef(),p);
      state.loading=false;render();
      alert(`تم استيراد ${out.length} مشروع بنجاح.`);
    }catch(e){console.error(e);state.loading=false;render();alert('تعذّرت قراءة ملف الإكسل.');}
  };
  reader.readAsBinaryString(file);
}
async function clearAll(){
  if(!confirm("تحذير: سيتم مسح كل المشاريع نهائياً ولا يمكن التراجع. متابعة؟")) return;
  state.loading=true;render();
  try{
    const snap=await getDocs(query(colRef()));
    const batch=writeBatch(db);
    snap.forEach(d=>batch.delete(d.ref));
    await batch.commit();
    alert("تم مسح جميع المشاريع.");
  }catch(e){console.error(e);alert("حدث خطأ أثناء المسح.");}
  state.loading=false;render();
}
async function saveProject(data,editingId){
  const payload={...data,lastUpdatedBy:state.appUser.name,lastUpdatedAt:new Date().toLocaleString('ar-OM')};
  if(editingId){await updateDoc(doc(db,'artifacts',APP_ID,'public','data','projects',editingId),payload);}
  else{await addDoc(colRef(),{...payload,createdAt:new Date().toISOString()});}
}
async function deleteProject(id){
  await deleteDoc(doc(db,'artifacts',APP_ID,'public','data','projects',id));
}

